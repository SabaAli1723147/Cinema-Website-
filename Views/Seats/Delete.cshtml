@model CinemaBookingApp.Models.Seat

@{
    ViewData["Title"] = "Delete Seat";
}

<h1>Delete Seat</h1>

<h4 class="text-danger">
    Are you sure you want to delete this seat?
</h4>

<hr />

<dl class="row">

    <dt class="col-sm-3">
        Hall
    </dt>

    <dd class="col-sm-9">
        @Model.Hall.HallName
    </dd>

    <dt class="col-sm-3">
        Seat Number
    </dt>

    <dd class="col-sm-9">
        @Model.SeatNumber
    </dd>

    <dt class="col-sm-3">
        Seat Type
    </dt>

    <dd class="col-sm-9">
        @Model.SeatType
    </dd>

    <dt class="col-sm-3">
        Status
    </dt>

    <dd class="col-sm-9">
        @Model.Status
    </dd>

</dl>

<form asp-action="Delete">

    <input type="hidden" asp-for="SeatID" />

    <input type="submit"
           value="Delete"
           class="btn btn-danger" />

    <a asp-action="Index"
           class="btn btn-secondary">
        Cancel
    </a>

</form>