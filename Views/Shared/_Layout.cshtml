<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CinemaBookingApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CinemaBookingApp.styles.css" asp-append-version="true" />
</head>
<body style="background-color: #121212; color: #ffffff;">
    <header>
        <nav class="navbar navbar-expand-sm border-bottom border-secondary px-4 py-3" style="background-color: #1a1a2e;">
            <div class="container-fluid d-flex justify-content-between align-items-center">

                <div class="d-flex align-items-center gap-4">
                    <a asp-controller="Home" asp-action="Index" class="navbar-logo fw-bold fs-4 text-decoration-none" style="color: #ff2d55; letter-spacing: 2px;">
                        <i class="fas fa-film"></i> CINEMA
                    </a>
                    <div class="d-flex gap-2">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-sm text-white fw-semibold border-0 btn-outline-light px-3 py-2">Home</a>
                        @if (User.Identity.IsAuthenticated)
                        {
                            <a asp-controller="Bookings" asp-action="MyBookings" class="btn btn-sm text-white fw-semibold border-0 btn-outline-light px-3 py-2">My Bookings</a>
                        }
                    </div>
                </div>

                <div class="dropdown">
                    <button class="btn border border-danger rounded-circle text-white d-flex align-items-center justify-content-center p-0 shadow-sm"
                            type="button" id="userMenuDropdown" data-bs-toggle="dropdown" aria-expanded="false"
                            style="background-color: #2a2145; width: 42px; height: 42px;">
                        <i class="fas fa-user"></i>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end p-2 border border-secondary shadow-lg dropdown-menu-dark"
                        aria-labelledby="userMenuDropdown"
                        style="background-color: #2a2145; min-width: 220px; border-radius: 12px;">

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li>
                                <div class="px-3 py-2 small text-muted">
                                    Signed in as <br />
                                    <strong class="text-white">@User.Identity.Name</strong>
                                </div>
                            </li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li>
                                    <a asp-controller="Bookings" asp-action="Index" class="dropdown-item rounded py-2">
                                        <i class="fas fa-gauge me-2 text-danger"></i> Admin Dashboard
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider border-secondary"></li>
                            }
                            <li>
                                <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post" class="m-0">
                                    <button type="submit" class="dropdown-item text-danger rounded py-2 border-0 bg-transparent w-100 text-start fw-semibold">
                                        <i class="fas fa-right-from-bracket me-2"></i> Logout
                                    </button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li><div class="px-3 py-1 small text-muted">Welcome, Guest</div></li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            <li>
                                <a asp-area="Identity" asp-page="/Account/Login" class="dropdown-item rounded py-2">
                                    <i class="fas fa-right-to-bracket me-2 text-danger"></i> Login
                                </a>
                            </li>
                            <li><hr class="dropdown-divider border-secondary"></li>
                            <li>
                                <a asp-area="Identity" asp-page="/Account/Register" class="dropdown-item rounded py-2">
                                    <i class="fas fa-user-plus me-2 text-danger"></i> Register
                                </a>
                            </li>
                        }
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <div class="container-fluid px-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="py-3 text-center" style="background-color: #0d0d1a; border-top: 1px solid rgba(255, 45, 85, 0.2); font-size: 14px; color: #8a8fa3; letter-spacing: 1px;">
        <div class="container">
            &copy; 2026 - CinemaBookingApp. All rights reserved.
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>