@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Access Denied – Cinema</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            min-height: 100vh;
            background: #0a0a0f;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            color: #fff;
            text-align: center;
        }

        .error-code {
            font-size: 6rem;
            font-weight: 900;
            color: #e50914;
        }

        .error-msg {
            font-size: 1.5rem;
            color: #aaa;
            margin: 10px 0 30px;
        }

        .btn-home {
            background: #e50914;
            color: #fff;
            padding: 12px 30px;
            border-radius: 8px;
            text-decoration: none;
            font-weight: 600;
        }

            .btn-home:hover {
                background: #b8070f;
                color: #fff;
            }
    </style>
</head>
<body>
    <div>
        <div class="error-code">403</div>
        <div class="error-msg">You don't have permission to view this page.</div>
        <a asp-controller="Home" asp-action="Index" class="btn-home">
            Back to Home
        </a>
    </div>
</body>
</html>