@model CinemaBookingApp.Models.Movie
@{
    ViewData["Title"] = Model.Title;
    Layout = null;
    var showTimes = ViewBag.ShowTimes as List<CinemaBookingApp.Models.ShowTime>;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@Model.Title - Cinema</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background: #0a0a0f;
            color: #fff;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar-cinema {
            background: #111;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .navbar-cinema .logo {
                color: #e50914;
                font-weight: 900;
                font-size: 1.4rem;
                text-decoration: none;
            }

            .navbar-cinema a {
                color: #ccc;
                text-decoration: none;
                margin-left: 20px;
            }

        .detail-wrap {
            max-width: 900px;
            margin: 40px auto;
            display: flex;
            gap: 30px;
            padding: 0 20px;
            flex-wrap: wrap;
        }

        .poster-lg {
            width: 260px;
            height: 380px;
            border-radius: 12px;
            flex-shrink: 0;
            background: linear-gradient(135deg,#e50914,#5a0509);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
        }

        .detail-info {
            flex: 1;
            min-width: 280px;
        }

            .detail-info h1 {
                font-weight: 800;
            }

        .badge-meta {
            background: #16161f;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: .8rem;
            color: #ccc;
            margin-right: 8px;
            display: inline-block;
            margin-bottom: 6px;
        }

        .desc {
            color: #bbb;
            margin-top: 16px;
            line-height: 1.6;
        }

        .showtimes-section {
            margin-top: 28px;
        }

            .showtimes-section h5 {
                font-weight: 700;
                margin-bottom: 14px;
            }

        .showtime-card {
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: #16161f;
            border: 1px solid #2a2a35;
            border-radius: 10px;
            padding: 14px 18px;
            margin-bottom: 10px;
            text-decoration: none;
            color: #fff;
            transition: border-color .15s, background .15s;
        }

            .showtime-card:hover {
                border-color: #e50914;
                background: #1c1c26;
                color: #fff;
            }

        .showtime-left {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .showtime-hall {
            font-weight: 600;
        }

        .showtime-meta {
            color: #999;
            font-size: .85rem;
        }

        .showtime-right {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .showtime-price {
            font-weight: 700;
            color: #e50914;
        }

        .no-showtimes {
            color: #888;
            padding: 14px 0;
        }

        @@media (max-width: 700px) {
            .detail-wrap {
                flex-direction: column;
                align-items: center;
            }
        }
    </style>
</head>
<body>
    <div class="navbar-cinema">
        <a asp-controller="Home" asp-action="Index" class="logo"><i class="fas fa-film"></i> CINEMA</a>
        <div>
            @if (User.Identity.IsAuthenticated)
            {
                <span class="me-3">Hi, @User.Identity.Name</span>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login">Login</a>
            }
        </div>
    </div>

    <div class="detail-wrap">
        <div class="poster-lg"><i class="fas fa-clapperboard"></i></div>
        <div class="detail-info">
            <h1>@Model.Title</h1>
            <div>
                <span class="badge-meta">@Model.Genre</span>
                <span class="badge-meta">Age @Model.AgeLimit+</span>
            </div>
            <p class="desc">@Model.Description</p>

            <div class="showtimes-section">
                <h5><i class="fas fa-clock me-1"></i> Select a Showtime</h5>

                @if (showTimes != null && showTimes.Any())
                {
                    foreach (var st in showTimes)
                    {
                        <a asp-controller="Bookings" asp-action="SelectSeats" asp-route-showTimeId="@st.ShowTimeID" class="showtime-card">
                            <div class="showtime-left">
                                <span class="showtime-hall">@(st.Hall != null ? st.Hall.HallName : "Hall TBA")</span>
                                <span class="showtime-meta">@st.Date.ToString("ddd, MMM d") &middot; @st.Time.ToString(@"hh\:mm")</span>
                            </div>
                            <div class="showtime-right">
                                <span class="showtime-price">@st.Price.ToString("0.00") $</span>
                                <i class="fas fa-chevron-right"></i>
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="no-showtimes">No showtimes scheduled yet for this movie.</div>
                }
            </div>
        </div>
    </div>
</body>
</html>