@model IEnumerable<CinemaBookingApp.Models.Seat>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@{
    ViewData["Title"] = "Seat Selection";
    // Pull the ShowTime data passed from the ViewBag in the Controller
    var showTime = ViewBag.ShowTime as CinemaBookingApp.Models.ShowTime;
    decimal ticketPrice = ViewBag.TicketPrice ?? 10;
}

<style>
    body {
        background-color: #121212;
        color: white;
    }

    .card {
        background: #1e1e2f;
        color: white;
        border: 1px solid #ff3b3b;
    }

    .seat-container {
        background-image: url('/images/cinema-screen.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        padding: 30px;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .screen {
        background: linear-gradient(to bottom, #2c2c2c, #1a1a1a);
        color: white;
        height: 60px;
        width: 80%;
        margin: auto;
        border-radius: 50% / 100%;
        text-align: center;
        line-height: 60px;
        font-size: 22px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(0,0,0,0.6);
    }

    .seat-row {
        display: flex;
        gap: 8px;
    }

    .seat {
        background-color: #6c757d;
        color: white;
        width: 55px;
        height: 45px;
        border-radius: 10px;
        border: 2px solid #ff3b3b;
        font-size: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

        .seat:hover {
            transform: scale(1.08);
            background-color: #5a6268;
        }

        .seat.selected {
            background-color: #28a745 !important;
            border-color: #28a745 !important;
        }

        .seat.reserved {
            background-color: #dc3545 !important;
            border-color: #dc3545 !important;
            cursor: not-allowed;
        }

    #selectedSeats {
        font-weight: bold;
        color: #28a745;
        min-height: 30px;
    }

    #ticketCount,
    #totalPrice {
        font-size: 22px;
        font-weight: bold;
    }
</style>

<div class="container mt-5">
    <div class="card shadow-lg rounded-4">
        <div class="card-body p-4">

            @if (showTime != null)
            {
                <h2 class="text-center mb-2 fw-bold">🎬 @showTime.Movie.Title</h2>
                <h5 class="text-center text-muted mb-4">🏛 @showTime.Hall.HallName | 📅 @showTime.Date.ToShortDateString() at @showTime.Time.ToString(@"hh\:mm")</h5>
            }
            else
            {
                <h2 class="text-center mb-4 fw-bold">🎟 Seat Selection</h2>
            }

            <div class="d-flex justify-content-center gap-4 mb-4">
                <span class="badge bg-secondary p-2">Available</span>
                <span class="badge bg-success p-2">Selected</span>
                <span class="badge bg-danger p-2">Reserved</span>
            </div>

            <div class="screen mb-5">
                SCREEN
            </div>

            <div class="seat-container">
                @for (int row = 0; row < 8; row++)
                {
                    char rowLetter = (char)('A' + row);
                    <div class="seat-row">
                        @for (int col = 1; col <= 10; col++)
                        {
                            string seatNum = $"{rowLetter}{col}";
                            // Look for matching seat data item from the DB model list
                            var currentSeat = Model.FirstOrDefault(s => s.SeatNumber == seatNum);
                            string seatStatusClass = currentSeat?.Status?.ToLower() == "reserved" ? "reserved" : "";

                            <button type="button"
                                    class="seat btn @seatStatusClass"
                                    data-id="@(currentSeat?.SeatID ?? 0)"
                                    data-seat="@seatNum"
                                    @(seatStatusClass == "reserved" ? "disabled" : "")>
                                @seatNum
                            </button>
                        }
                    </div>
                }
            </div>

            <hr class="mt-5" />

            <div class="row mt-4">
                <div class="col-md-4">
                    <h5><i class="bi bi-people-fill"></i> Selected Seats</h5>
                    <p id="selectedSeats">None</p>
                </div>

                <div class="col-md-4">
                    <h5><i class="bi bi-ticket-perforated"></i> Tickets</h5>
                    <p id="ticketCount">0</p>
                </div>

                <div class="col-md-4">
                    <h5><i class="bi bi-currency-dollar"></i> Total Price</h5>
                    <p><strong><span id="totalPrice">0</span> LYD</strong></p>
                </div>
            </div>

            <form asp-action="ConfirmBooking" method="post" class="text-center mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="showTimeId" value="@(showTime?.ShowTimeID ?? 0)" />
                <input type="hidden" id="hiddenSeatId" name="seatId" value="" />

                <button type="submit" id="btnConfirm" class="btn btn-success btn-lg px-5" disabled>
                    Confirm Booking
                </button>
            </form>

        </div>
    </div>
</div>

<script>
    const ticketPrice = @ticketPrice;

    const seats = document.querySelectorAll('.seat:not(.reserved)');
    const selectedSeatsText = document.getElementById('selectedSeats');
    const ticketCountText = document.getElementById('ticketCount');
    const totalPriceText = document.getElementById('totalPrice');
    const hiddenSeatIdInput = document.getElementById('hiddenSeatId');
    const btnConfirm = document.getElementById('btnConfirm');

    seats.forEach(seat => {
        seat.addEventListener('click', function () {
            this.classList.toggle('selected');
            updateSummary();
        });
    });

    function updateSummary() {
        const selected = document.querySelectorAll('.seat.selected');

        // Map display strings
        const seatNumbers = [...selected].map(s => s.dataset.seat);
        selectedSeatsText.textContent = seatNumbers.length ? seatNumbers.join(', ') : 'None';
        ticketCountText.textContent = seatNumbers.length;
        totalPriceText.textContent = seatNumbers.length * ticketPrice;

        // Extract internal Database Primary Keys (SeatIDs)
        const seatIds = [...selected].map(s => s.dataset.id);

        if(seatIds.length > 0) {
            // For now, passes the first selected seat ID to match your single seatId controller action parameter
            hiddenSeatIdInput.value = seatIds[0];
            btnConfirm.removeAttribute('disabled');
        } else {
            hiddenSeatIdInput.value = "";
            btnConfirm.setAttribute('disabled', 'true');
        }
    }
</script>