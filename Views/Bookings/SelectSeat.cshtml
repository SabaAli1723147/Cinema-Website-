@model CinemaBookingApp.Models.ShowTime

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

@{
    ViewData["Title"] = "Seat Selection";
}

<style>

    body {
        background-color: #121212;
        color: white;
    }

    .card {
        background: #1e1e2f;
        color: white;
        border: 1px solid #ff3b3b;
    }

    .seat-container {
        background-image: url('/images/cinema-screen.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        padding: 30px;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .screen {
        background: linear-gradient(to bottom, #2c2c2c, #1a1a1a);
        color: white;
        height: 60px;
        width: 80%;
        margin: auto;
        border-radius: 50% / 100%;
        text-align: center;
        line-height: 60px;
        font-size: 22px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(0,0,0,0.6);
    }

    .seat-row {
        display: flex;
        gap: 8px;
    }

    .seat {
        background-color: #6c757d;
        color: white;
        width: 55px;
        height: 45px;
        border-radius: 10px;
        /* 🔴 border أحمر حسب طلبك */
        border: 2px solid #ff3b3b;
        font-size: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

        .seat:hover {
            transform: scale(1.08);
            background-color: #5a6268;
        }

        .seat.selected {
            background-color: #28a745 !important;
            border-color: #28a745 !important;
        }

        .seat.reserved {
            background-color: #dc3545 !important;
            border-color: #dc3545 !important;
            cursor: not-allowed;
        }

    #selectedSeats {
        font-weight: bold;
        color: #28a745;
        min-height: 30px;
    }

    #ticketCount,
    #totalPrice {
        font-size: 22px;
        font-weight: bold;
    }

</style>

<div class="container mt-5">

    <div class="card shadow-lg rounded-4">

        <div class="card-body p-4">

            <h2 class="text-center mb-4 fw-bold">
                🎟 Seat Selection
            </h2>

            <!-- Legend -->
            <div class="d-flex justify-content-center gap-4 mb-4">

                <span class="badge bg-secondary p-2">Available</span>
                <span class="badge bg-success p-2">Selected</span>
                <span class="badge bg-danger p-2">Reserved</span>

            </div>

            <!-- Screen -->
            <div class="screen mb-5">
                SCREEN
            </div>

            <!-- Seats -->
            <div class="seat-container">

                @for (int row = 0; row < 8; row++)
                {
                    <div class="seat-row">

                        @for (int col = 1; col <= 10; col++)
                        {
                            <button type="button"
                                    class="seat btn"
                                    data-seat="@((char)('A' + row))@col">

                                @((char)('A' + row))@col

                            </button>
                        }

                    </div>
                }

            </div>

            <hr class="mt-5" />

            <!-- Summary -->
            <div class="row mt-4">

                <div class="col-md-4">
                    <h5><i class="bi bi-people-fill"></i> Selected Seats</h5>
                    <p id="selectedSeats">None</p>
                </div>

                <div class="col-md-4">
                    <h5><i class="bi bi-ticket-perforated"></i> Tickets</h5>
                    <p id="ticketCount">0</p>
                </div>

                <div class="col-md-4">
                    <h5><i class="bi bi-currency-dollar"></i> Total Price</h5>
                    <p><strong><span id="totalPrice">0</span> LYD</strong></p>
                </div>

            </div>

            <div class="text-center mt-4">

                <button class="btn btn-success btn-lg px-5">
                    Confirm Booking
                </button>

            </div>

        </div>
    </div>
</div>

<script>

    const ticketPrice = 10;

    const seats = document.querySelectorAll('.seat');
    const selectedSeatsText = document.getElementById('selectedSeats');
    const ticketCountText = document.getElementById('ticketCount');
    const totalPriceText = document.getElementById('totalPrice');

    seats.forEach(seat => {

        seat.addEventListener('click', function () {

            if (this.classList.contains('reserved'))
                return;

            this.classList.toggle('selected');

            updateSummary();
        });
    });

    function updateSummary() {

        const selected = document.querySelectorAll('.seat.selected');

        const seatNumbers = [...selected].map(s => s.dataset.seat);

        selectedSeatsText.textContent =
            seatNumbers.length ? seatNumbers.join(', ') : 'None';

        ticketCountText.textContent = seatNumbers.length;

        totalPriceText.textContent = seatNumbers.length * ticketPrice;
    }

</script>