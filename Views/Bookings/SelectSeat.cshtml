@model CinemaBookingApp.Models.ShowTime

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
@{
    ViewData["Title"] = "Seat Selection";
}
<style>
    .seat-container {
        background-image: url('/images/cinema-screen.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        padding: 30px;
        border-radius: 20px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .screen {
        background: linear-gradient(to bottom, #f8f9fa, #dcdcdc);
        height: 60px;
        width: 80%;
        margin: auto;
        border-radius: 50% / 100%;
        text-align: center;
        line-height: 60px;
        font-size: 22px;
        font-weight: bold;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .seat-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    .seat-row {
        display: flex;
        gap: 8px;
    }

    .seat {
        background-color: #6c757d;
        color: white ;
        border-color: none;
        width: 55px;
        height: 45px;
        border-radius: 10px;
        font-size: 12px;
        font-weight: bold;
        transition: 0.3s;
    }

        .seat:hover {
            transform: scale(1.08);
            background-color: #5a6268;
        }

        .seat.selected {
            background-color: #28a745 !important;
            color: white !important;
            border-color: #28a745 !important;
        }

        .seat.reserved {
            background-color: #dc3545 !important;
            color: white !important;
            border-color: #dc3545 !important;
            cursor: not-allowed;
        }

    .card {
        background: #ffffff;
    }

    #selectedSeats {
        font-weight: bold;
        color: #28a745;
        min-height: 30px;
    }

    #ticketCount,
    #totalPrice {
        font-size: 22px;
        font-weight: bold;
    }

</style>

<div class="container mt-5">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-4">

            <h2 class="text-center mb-4 fw-bold">
                🎟 Seat Selection
            </h2>

            <!-- Seat Status -->

            <div class="d-flex justify-content-center gap-4 mb-4">

                <div>
                    <span class="badge bg-secondary p-2">
                        Available
                    </span>
                </div>

                <div>
                    <span class="badge bg-success p-2">
                        Selected
                    </span>
                </div>

                <div>
                    <span class="badge bg-danger p-2">
                        Reserved
                    </span>
                </div>

            </div>


            <!-- Screen -->

            <div class="screen text-center mb-5">

                SCREEN

            </div>


            <!-- Seats -->
            <div class="seat-container">

                @for (int row = 0; row < 8; row++)
                {
                    <div class="seat-row">

                        @for (int col = 1; col <= 10; col++)
                        {
                            <button type="button"
                                    class="seat btn btn-outline-secondary"
                                    data-seat="@((char)('A' + row))@col">

                                @((char)('A' + row))@col

                            </button>
                        }

                    </div>
                }

            </div>

            <hr class="mt-5" />
            }

            <!-- Summary -->

            <div class="row mt-4">

                <div class="col-md-4">

                    <h5>
                        <i class="bi bi-people-fill"></i>
                        Selected Seats
                    </h5>

                    <p id="selectedSeats">
                        None
                    </p>

                </div>

                <div class="col-md-4">

                    <h5>
                        <i class="bi bi-ticket-perforated"></i>
                        Tickets
                    </h5>

                    <p id="ticketCount">
                        0
                    </p>

                </div>

                <div class="col-md-4">

                    <h5>
                        <i class="bi bi-currency-dollar"></i>
                        Total Price
                    </h5>

                    <p>
                        <strong>
                            <span id="totalPrice">0</span> LYD
                        </strong>
                    </p>

                </div>

            </div>


            <div class="text-center mt-4">

                <button class="btn btn-success btn-lg px-5">

                    Confirm Booking

                </button>

            </div>

        </div>

    </div>

</div>
<script>
    const ticketPrice = 10;

    const seats = document.querySelectorAll('.seat');
    const selectedSeatsText = document.getElementById('selectedSeats');
    const ticketCountText = document.getElementById('ticketCount');
    const totalPriceText = document.getElementById('totalPrice');

    // مقاعد محجوزة مسبقاً
   // const reservedSeats = [
       // "C5",
       // "D10",
     //  "F3",
       // "F11",
        //"G6",
        //"G12"
    //];

    seats.forEach(seat => {

        const seatNumber = seat.dataset.seat;

       // if (reservedSeats.includes(seatNumber)) {
         //   seat.classList.add('reserved');
           // seat.disabled = true;
        //}

        seat.addEventListener('click', function () {

            if (this.classList.contains('reserved'))
                return;

            this.classList.toggle('selected');

            updateSummary();
        });
    });

    function updateSummary() {

        const selected = document.querySelectorAll('.seat.selected');

        const seatNumbers = [...selected].map(
            seat => seat.dataset.seat
        );

        selectedSeatsText.textContent =
            seatNumbers.length > 0
                ? seatNumbers.join(', ')
                : 'None';

        ticketCountText.textContent =
            seatNumbers.length;

        totalPriceText.textContent =
            seatNumbers.length * ticketPrice;
    }
</script>