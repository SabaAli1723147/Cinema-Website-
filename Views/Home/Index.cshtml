@model List<CinemaBookingApp.Models.Movie>

@{

	ViewData["Title"] = "Home";

	Layout = null;

}
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<title>Cinema - Home</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

	<style>

		body {
			background: #0a0a0f;
			color: #fff;
			font-family: 'Segoe UI', sans-serif;
		}

		.navbar-cinema {
			background: #111;
			padding: 16px 40px;
			display: flex;
			justify-content: space-between;
			align-items: center;
		}

			.navbar-cinema .logo {
				color: #e50914;
				font-weight: 900;
				font-size: 1.4rem;
			}

			.navbar-cinema a {
				color: #ccc;
				text-decoration: none;
				margin-left: 20px;
			}

				.navbar-cinema a:hover {
					color: #fff;
				}

		.hero {
			padding: 60px 40px 30px;
			text-align: center;
		}

			.hero h1 {
				font-weight: 800;
				font-size: 2.2rem;
			}

			.hero p {
				color: #999;
			}

		.movie-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(180px,1fr));
			gap: 24px;
			padding: 20px 40px 60px;
		}

		.movie-card {
			background: #16161f;
			border-radius: 10px;
			overflow: hidden;
			transition: transform .2s;
		}

			.movie-card:hover {
				transform: translateY(-5px);
			}

			.movie-card .poster {
				height: 240px;
				background: linear-gradient(135deg,#e50914,#5a0509);
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2.5rem;
			}

			.movie-card .info {
				padding: 14px;
			}

			.movie-card h5 {
				font-size: 1rem;
				margin-bottom: 4px;
			}

			.movie-card .meta {
				color: #888;
				font-size: .8rem;
			}
		
			.btn-book {
			background: #e50914;
			border: none;
			color: #fff;
			width: 100%;
			padding: 8px;
			border-radius: 6px;
			margin-top: 10px;
			font-weight: 600;
		}
			
		.btn-book:hover {
				background: #b8070f;
				color: #fff;
			}
		
			.empty-state {
			text-align: center;
			padding: 60px;
			color: #888;
		}
	</style>
</head>
<body>
	<div class="navbar-cinema">
		<div class="logo"><i class="fas fa-film"></i> CINEMA</div>
		<div>
			@if (User.Identity.IsAuthenticated)
			{
				<span class="me-3">Hi, @User.Identity.Name</span>
				<form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">

					@Html.AntiForgeryToken()

					<button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
				</form>
			}
			else
			{
				<a asp-controller="Account" asp-action="Login">Login</a>
				<a asp-controller="Account" asp-action="Register">Register</a>
			}
		</div>
	</div>
	<div class="hero">
		<h1>Now Showing</h1>
		<p>Book your favorite movies in just a few clicks</p>
	</div>
	@if (Model != null && Model.Any())
	{
		<div class="movie-grid">
			@foreach (var movie in Model)
			{
				<div class="movie-card">
					<div class="poster"><i class="fas fa-clapperboard"></i></div>
					<div class="info">
						<h5>@movie.Title</h5>
						<div class="meta">@movie.Genre &middot; Age @movie.AgeLimit+</div>
						<a asp-controller="Movies" asp-action="Details" asp-route-id="@movie.MovieID" 
						    class="btn-book" style="display:block;text-align:center;text-decoration:none;">View Showtimes</a>
					</div>
				</div>
			}
		</div>
	}
	else
	{
		<div class="empty-state">
			<i class="fas fa-film fa-2x mb-3"></i>
			<p>No movies available yet. Check back soon!</p>
		</div>
	}
</body>
</html>

