@model IEnumerable<CinemaBookingApp.Models.ShowTime>

@{
    ViewData["Title"] = "Index";
}

<h1 class="mb-4">Show Times</h1>
<form asp-action="Index" method="get" class="row mb-3">
    <div class="col-md-4">
        <input type="text"
               name="searchString"
               value="@ViewData["CurrentFilter"]"
               class="form-control"
               placeholder="Search by movie or hall..." />
    </div>

    <div class="col-md-auto">
        <input type="submit"
               value="Search"
               class="btn btn-outline-primary" />
    </div>
</form>
<p>
    <a asp-action="Create" class="btn btn-primary">
        Create New Show Time
    </a>
</p>
<table class="table table-striped table-bordered table-hover">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Movie)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Hall)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Date)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Time)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Price)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Status)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                    @item.Movie.Title
            </td>
            <td>
                    @item.Hall.HallName
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Date)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Time)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Price)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Status)
            </td>
            <td>
                    <a asp-action="Edit"
                           asp-route-id="@item.ShowTimeID"
                           class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Details"
                           asp-route-id="@item.ShowTimeID"
                           class="btn btn-info btn-sm text-white">
                        Details
                    </a>

                    <a asp-action="Delete"
                           asp-route-id="@item.ShowTimeID"
                           class="btn btn-danger btn-sm">
                        Delete
                    </a>
            </td>
        </tr>
}
    </tbody>
</table>
