@model CinemaBookingApp.Models.CinemaHall

@{
    ViewData["Title"] = "Edit Cinema Hall";
}

<h1>Edit Cinema Hall</h1>

<hr />

<div class="row">

    <div class="col-md-5">

        <form asp-action="Edit">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger">
            </div>

            <input type="hidden"
                   asp-for="HallID" />

            <div class="form-group mb-3">

                <label asp-for="HallName"></label>

                <input asp-for="HallName"
                       class="form-control" />

                <span asp-validation-for="HallName"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="Capacity"></label>

                <input asp-for="Capacity"
                       class="form-control" />

                <span asp-validation-for="Capacity"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group">

                <input type="submit"
                       value="Save"
                       class="btn btn-warning" />

                <a asp-action="Index"
                       class="btn btn-secondary">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}